# Confluence Data Center
CONFLUENCE_URL=https://your-confluence.company.com
CONFLUENCE_USERNAME=your_username
# Personal Access Token (Confluence 7.9+) veya password
CONFLUENCE_TOKEN=your_personal_access_token

# pgvector Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASSWORD=your_db_password

# LiteLLM Proxy (local embedding servisi)
LITELLM_BASE_URL=http://localhost:4000
# Yerel kurulum için dummy key yeterli, proxy API key gerektiriyorsa gir
LITELLM_API_KEY=dummy
# LiteLLM'de tanımlı model adı (örn. ollama/nomic-embed-text, huggingface/..., vb.)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
