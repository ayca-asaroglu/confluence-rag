# Confluence Data Center
CONFLUENCE_URL=https://your-confluence.company.com
CONFLUENCE_USERNAME=your_username
# Personal Access Token (Confluence 7.9+) veya password
CONFLUENCE_TOKEN=your_personal_access_token
# Tek ya da virgülle ayrılmış birden fazla space key
CONFLUENCE_SPACE_KEY=SPACE1,SPACE2

# pgvector Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASSWORD=your_db_password

# Yerel Embedding Servisi
LITELLM_BASE_URL=https://your-embedding-service/v1/embeddings
LITELLM_API_KEY=your_api_key
EMBEDDING_MODEL=llama-embed-nemotron-8b
EMBEDDING_DIM=1536
EMBEDDING_TIMEOUT=120

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
