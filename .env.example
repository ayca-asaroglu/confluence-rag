# Confluence Data Center
CONFLUENCE_URL=https://your-confluence.company.com
CONFLUENCE_USERNAME=your_username
# Personal Access Token (Confluence 7.9+) veya password
CONFLUENCE_TOKEN=your_personal_access_token

# pgvector Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASSWORD=your_db_password

# OpenAI Embeddings
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
# text-embedding-3-small -> dim: 1536
# text-embedding-3-large -> dim: 3072
# text-embedding-ada-002  -> dim: 1536
EMBEDDING_DIM=1536

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
